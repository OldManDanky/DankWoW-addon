# Libraries are loaded first from embeds.xml (keeps the TOC clean).
embeds.xml

# Core — constants first (creates the DankWoWPlayerbots namespace used by everything).
Core\Constants.lua

# Locales — string tables. enUS is the fallback; other locales overlay.
Locales\enUS.lua

# Core continued — styling, config, comms, roster, and lifecycle.
Core\Skin.lua
Core\Config.lua
Core\Comm.lua
Core\Presets.lua
Core\BotRoster.lua
Core\BotManager.lua
Core\Core.lua

# UI — main panel, portraits, command bar.
# Load leaf components before the composite frame that uses them.
UI\CommandBar.lua
UI\StrategyPanel.lua
UI\BotPortrait.lua
UI\BotManagerFrame.lua
UI\OptionsPanel.lua
UI\ActionBar.lua
UI\MainFrame.lua
UI\MinimapButton.lua
